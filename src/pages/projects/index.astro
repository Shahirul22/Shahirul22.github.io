---
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { projects } from '../../lib/data';
---
<Base title="Projects — Shahirul Amin">
  <section class="container-prose pt-16 pb-10">
    <a href="/" class="text-sm font-mono text-ink-500 dark:text-ink-400 hover:text-accent">← back home</a>
    <p class="section-eyebrow mt-4">// projects</p>
    <h1 class="section-title mt-2 text-4xl sm:text-5xl">Things I've built</h1>
    <p class="mt-4 text-ink-600 dark:text-ink-300 max-w-2xl">
      A selection of production systems, migrations, and internal tooling. Some clients are government agencies,
      so source and live URLs are private — but case studies cover the architecture.
    </p>
  </section>

  <section class="container-prose">
    <div class="grid md:grid-cols-2 gap-6">
      {projects.map((p, i) => <ProjectCard project={p} index={i} />)}
    </div>
  </section>
</Base>
