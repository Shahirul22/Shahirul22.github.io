---
import Base from '../layouts/Base.astro';
import HeroTerminal from '../components/HeroTerminal.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Timeline from '../components/Timeline.astro';
import SkillTiers from '../components/SkillTiers.tsx';
import SkillBars from '../components/SkillBars.tsx';
import StatCounter from '../components/StatCounter.tsx';
import { site } from '../lib/site';
import { projects } from '../lib/data';

const featured = projects.slice(0, 4);
---
<Base>
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 grid-bg animate-gridmove opacity-60 pointer-events-none"></div>
    <div class="container-prose pt-16 pb-20 sm:pt-24 sm:pb-28 relative">
      <div class="grid lg:grid-cols-2 gap-10 items-center">
        <div class="reveal">
          <p class="section-eyebrow mb-3">// senior software developer</p>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.1]">
            Hi, I'm <span class="gradient-text">Shahirul</span>.
            <br/>
            I build <span class="text-accent">backends</span> that scale.
          </h1>
          <p class="mt-6 text-lg text-ink-600 dark:text-ink-300 max-w-xl">
            Backend-focused developer specialising in <span class="font-semibold text-ink-900 dark:text-ink-50">Laravel</span> — APIs,
            workflow systems, RBAC, and developer tooling. Based in Penang, Malaysia.
          </p>
          <div class="mt-8 flex flex-wrap items-center gap-3">
            <a href="#projects" class="btn-primary">
              View projects
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <a href="#contact" class="btn-ghost">Get in touch</a>
            <a href={site.resume} target="_blank" rel="noreferrer" class="btn-ghost">Resume ↗</a>
          </div>
          <div class="mt-8 flex items-center gap-4 text-xs font-mono text-ink-500 dark:text-ink-400">
            <span class="inline-flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-terminal-green animate-pulse"></span>
              Available for collaboration
            </span>
            <span>📍 {site.location}</span>
          </div>
        </div>
        <div class="lg:pl-6">
          <HeroTerminal />
        </div>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="container-prose -mt-6 reveal">
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3 sm:gap-4">
      {[
        { label: 'Years coding', end: 6, suffix: '+' },
        { label: 'Production apps', end: 8, suffix: '+' },
        { label: 'Cups of coffee', end: 9999, prefix: '~' },
      ].map((s) => (
        <div class="card !p-5 text-center">
          <div class="text-3xl sm:text-4xl font-bold text-accent">
            <StatCounter client:visible end={s.end} suffix={s.suffix || ''} prefix={s.prefix || ''} />
          </div>
          <div class="mt-1 text-xs uppercase tracking-widest text-ink-500 dark:text-ink-400">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="container-prose mt-24">
    <div class="grid md:grid-cols-3 gap-10">
      <div class="reveal">
        <p class="section-eyebrow">// 01</p>
        <h2 class="section-title mt-2">About</h2>
      </div>
      <div class="md:col-span-2 reveal space-y-4 text-ink-700 dark:text-ink-300 leading-relaxed">
        <p>
          I'm a backend-focused software developer with a strong emphasis on building <strong class="text-ink-900 dark:text-ink-50">scalable
          APIs</strong>, web applications, and developer tooling. PHP and Laravel are my home turf, but I'm comfortable across
          full-stack web workflows and containerised environments.
        </p>
        <p>
          Currently, I'm a <strong class="text-ink-900 dark:text-ink-50">Senior Software Developer</strong> at Nindatech, leading
          the backend migration of <a class="text-accent hover:underline" href="https://eventilla.com" target="_blank" rel="noreferrer">Eventilla</a> from
          a legacy PHP framework to a modern Laravel + React stack. Before that, I spent two and a half years at MBPP
          (Penang Island City Council) building internal systems and running web/DB infrastructure on Nutanix HCI.
        </p>
        <p>
          I use AI tooling as part of my delivery workflow — for scaffolding, code review, and debugging — while owning the architecture and every line I commit.
          I'm also a part-time Software Engineering degree student at UTM Space.
        </p>
        <div class="flex flex-wrap gap-2 pt-2">
          <span class="badge">🇲🇾 Bahasa Melayu</span>
          <span class="badge">🇬🇧 English</span>
          <span class="badge">🇮🇳 Tamil</span>
        </div>
      </div>
    </div>
  </section>

  <!-- SKILLS -->
  <section id="skills" class="container-prose mt-24">
    <div class="text-center reveal">
      <p class="section-eyebrow">// 02</p>
      <h2 class="section-title mt-2">Skills & technologies</h2>
      <p class="mt-3 text-ink-600 dark:text-ink-400 max-w-2xl mx-auto">
        Strongest where it matters — backend, databases, and the workflows that hold systems together.
      </p>
    </div>
    <div class="mt-10 grid lg:grid-cols-2 gap-10 items-start">
      <div class="reveal">
        <SkillTiers client:visible />
      </div>
      <div class="card reveal">
        <h3 class="font-mono text-sm text-ink-500 dark:text-ink-400 mb-4">network_topology.svg</h3>
        <SkillBars client:visible />
      </div>
    </div>
  </section>

  <!-- EXPERIENCE -->
  <section id="experience" class="container-prose mt-24">
    <div class="reveal">
      <p class="section-eyebrow">// 03</p>
      <h2 class="section-title mt-2">Experience</h2>
      <p class="mt-3 text-ink-600 dark:text-ink-400 max-w-2xl">
        A timeline from training programmers, to building government systems, to leading SaaS migrations.
      </p>
    </div>
    <div class="mt-10">
      <Timeline />
    </div>
  </section>

  <!-- PROJECTS -->
  <section id="projects" class="container-prose mt-24">
    <div class="flex items-end justify-between gap-4 reveal">
      <div>
        <p class="section-eyebrow">// 04</p>
        <h2 class="section-title mt-2">Selected projects</h2>
        <p class="mt-3 text-ink-600 dark:text-ink-400 max-w-2xl">
          Production systems, internal tooling, and migrations. Click through for case studies.
        </p>
      </div>
      <a href="/projects/" class="btn-ghost hidden sm:inline-flex">All projects →</a>
    </div>

    <div class="mt-10 grid md:grid-cols-2 gap-6">
      {featured.map((p, i) => <ProjectCard project={p} index={i} />)}
    </div>
    <div class="mt-6 sm:hidden">
      <a href="/projects/" class="btn-ghost w-full justify-center">All projects →</a>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="container-prose mt-24">
    <div class="card reveal !p-10 text-center relative overflow-hidden">
      <div class="absolute inset-0 grid-bg opacity-40 pointer-events-none"></div>
      <div class="relative">
        <p class="section-eyebrow">// 05</p>
        <h2 class="section-title mt-2">Let's build something.</h2>
        <p class="mt-3 text-ink-600 dark:text-ink-300 max-w-xl mx-auto">
          Got a backend project, an audit, or just want to chat about Laravel architecture?
          The fastest way to reach me is email.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a href={`mailto:${site.email}?subject=Hello%20from%20your%20portfolio`} class="btn-primary">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            {site.email}
          </a>
          <a href={site.github} target="_blank" rel="noreferrer" class="btn-ghost">GitHub →</a>
          <a href={site.linkedin} target="_blank" rel="noreferrer" class="btn-ghost">LinkedIn →</a>
        </div>
      </div>
    </div>
  </section>
</Base>
