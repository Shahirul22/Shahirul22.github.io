---
import type { ProjectMeta } from '../lib/data';
interface Props { project: ProjectMeta; index?: number }
const { project, index = 0 } = Astro.props;
const hasDetail = ['asset-compliance', 'hr-management-suite'].includes(project.slug);
const href = hasDetail ? `/projects/${project.slug}/` : `/projects/`;
---
<a href={href} class="card group block reveal" style={`transition-delay:${index * 100}ms`}>
  <div class="flex items-start justify-between gap-3 mb-3">
    <h3 class="text-lg font-bold text-ink-900 dark:text-ink-50 group-hover:text-accent transition">
      {project.title}
    </h3>
    <span class="badge-accent shrink-0">{project.status}</span>
  </div>
  <p class="text-sm text-ink-600 dark:text-ink-300 mb-3">{project.tagline}</p>
  <p class="text-sm text-ink-500 dark:text-ink-400 mb-4 italic border-l-2 border-accent/40 pl-3">
    {project.highlight}
  </p>
  {project.metrics && (
    <div class="grid grid-cols-3 gap-2 mb-4">
      {project.metrics.map((m) => (
        <div class="text-center rounded-lg border border-ink-200 dark:border-ink-800 px-2 py-2 bg-ink-50/60 dark:bg-ink-900/60">
          <div class="font-mono text-accent text-sm">{m.value}</div>
          <div class="text-[10px] uppercase tracking-wider text-ink-500 dark:text-ink-400">{m.label}</div>
        </div>
      ))}
    </div>
  )}
  <div class="flex flex-wrap gap-1.5">
    {project.stack.slice(0, 5).map((t) => <span class="badge">{t}</span>)}
    {project.stack.length > 5 && <span class="badge">+{project.stack.length - 5}</span>}
  </div>
  {hasDetail && (
    <div class="mt-4 inline-flex items-center text-sm font-mono text-accent opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all">
      Read case study →
    </div>
  )}
</a>
