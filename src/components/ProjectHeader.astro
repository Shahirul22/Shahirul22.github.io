---
interface Props {
  title: string;
  tagline: string;
  status: string;
  stack: string[];
  metrics?: { label: string; value: string }[];
}
const { title, tagline, status, stack, metrics } = Astro.props;
---
<section class="container-prose pt-12 pb-10 relative">
  <div class="absolute inset-0 grid-bg opacity-50 pointer-events-none -z-10"></div>
  <a href="/projects/" class="text-sm font-mono text-ink-500 dark:text-ink-400 hover:text-accent">← all projects</a>
  <div class="mt-4 flex flex-wrap items-center gap-3">
    <span class="badge-accent">{status}</span>
  </div>
  <h1 class="mt-3 text-4xl sm:text-5xl font-extrabold tracking-tight">{title}</h1>
  <p class="mt-3 text-lg text-ink-600 dark:text-ink-300 max-w-3xl">{tagline}</p>

  <div class="mt-6 flex flex-wrap gap-1.5">
    {stack.map((t) => <span class="badge">{t}</span>)}
  </div>

  {metrics && (
    <div class="mt-8 grid grid-cols-2 sm:grid-cols-4 gap-3">
      {metrics.map((m) => (
        <div class="card !p-4 text-center">
          <div class="text-2xl font-bold text-accent font-mono">{m.value}</div>
          <div class="text-xs uppercase tracking-widest text-ink-500 dark:text-ink-400 mt-1">{m.label}</div>
        </div>
      ))}
    </div>
  )}
</section>
