---
// Cycles: system -> light -> dark -> system
---
<button
  id="theme-toggle"
  type="button"
  aria-label="Toggle color theme"
  class="relative inline-flex items-center justify-center w-9 h-9 rounded-lg border border-ink-200 dark:border-ink-700 bg-white/60 dark:bg-ink-900/60 backdrop-blur text-ink-700 dark:text-ink-200 hover:border-accent hover:text-accent transition"
>
  <!-- sun -->
  <svg data-icon="light" class="w-4 h-4 hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
  </svg>
  <!-- moon -->
  <svg data-icon="dark" class="w-4 h-4 hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
  <!-- system -->
  <svg data-icon="system" class="w-4 h-4 hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <rect x="3" y="4" width="18" height="12" rx="2"/><path d="M8 20h8M12 16v4"/>
  </svg>
</button>

<script is:inline>
  (function () {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    const root = document.documentElement;
    const icons = btn.querySelectorAll('[data-icon]');
    const mql = window.matchMedia('(prefers-color-scheme: dark)');

    function getPref() { return localStorage.getItem('theme') || 'system'; }
    function effective(pref) { return pref === 'system' ? (mql.matches ? 'dark' : 'light') : pref; }
    function apply() {
      const pref = getPref();
      root.classList.toggle('dark', effective(pref) === 'dark');
      icons.forEach((el) => el.classList.toggle('hidden', el.getAttribute('data-icon') !== pref));
    }
    function cycle() {
      const order = ['system', 'light', 'dark'];
      const next = order[(order.indexOf(getPref()) + 1) % order.length];
      localStorage.setItem('theme', next);
      apply();
    }
    btn.addEventListener('click', cycle);
    mql.addEventListener('change', () => { if (getPref() === 'system') apply(); });
    apply();
  })();
</script>
