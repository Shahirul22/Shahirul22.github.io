---
import ThemeToggle from './ThemeToggle.astro';
import { nav, site } from '../lib/site';
const pathname = Astro.url.pathname;
---
<header class="sticky top-0 z-40 backdrop-blur-md bg-white/70 dark:bg-ink-950/70 border-b border-ink-200/60 dark:border-ink-800/60">
  <nav class="container-prose flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-2 group">
      <span class="font-mono text-accent text-lg">{'<'}</span>
      <span class="font-bold tracking-tight text-ink-900 dark:text-ink-50 group-hover:text-accent transition">shahirul</span>
      <span class="font-mono text-accent text-lg">{'/>'}</span>
    </a>

    <ul class="hidden md:flex items-center gap-1">
      {nav.map((item) => {
        const active = item.href === '/' ? pathname === '/' : pathname.startsWith(item.href.split('#')[0]) && !item.href.includes('#');
        return (
          <li>
            <a
              href={item.href}
              class={`px-3 py-2 rounded-md text-sm font-medium transition hover:text-accent ${
                active ? 'text-accent' : 'text-ink-600 dark:text-ink-300'
              }`}
            >
              {item.label}
            </a>
          </li>
        );
      })}
    </ul>

    <div class="flex items-center gap-2">
      <a href={site.github} target="_blank" rel="noreferrer"
         aria-label="GitHub"
         class="hidden sm:inline-flex items-center justify-center w-9 h-9 rounded-lg border border-ink-200 dark:border-ink-700 text-ink-700 dark:text-ink-200 hover:border-accent hover:text-accent transition">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5A12 12 0 0 0 0 12.6c0 5.3 3.4 9.8 8.2 11.4.6.1.8-.3.8-.6v-2.2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1.1-.8.1-.8.1-.8 1.3.1 1.9 1.3 1.9 1.3 1.1 1.9 2.9 1.4 3.6 1 .1-.8.4-1.4.8-1.7-2.7-.3-5.5-1.4-5.5-6 0-1.3.5-2.4 1.2-3.3-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.3a11 11 0 0 1 6 0c2.3-1.6 3.3-1.3 3.3-1.3.7 1.7.3 2.9.2 3.2.8.9 1.2 2 1.2 3.3 0 4.7-2.8 5.7-5.5 6 .4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 24 12.6 12 12 0 0 0 12 .5z"/></svg>
      </a>
      <ThemeToggle />
      <button id="mobile-nav-toggle" class="md:hidden inline-flex items-center justify-center w-9 h-9 rounded-lg border border-ink-200 dark:border-ink-700" aria-label="Toggle navigation">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </nav>

  <div id="mobile-nav" class="md:hidden hidden border-t border-ink-200/60 dark:border-ink-800/60 bg-white/90 dark:bg-ink-950/90">
    <ul class="container-prose py-3 flex flex-col">
      {nav.map((item) => (
        <li>
          <a href={item.href} class="block px-3 py-2 rounded-md text-sm text-ink-700 dark:text-ink-200 hover:text-accent">{item.label}</a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script is:inline>
  const t = document.getElementById('mobile-nav-toggle');
  const m = document.getElementById('mobile-nav');
  t?.addEventListener('click', () => m?.classList.toggle('hidden'));
</script>
