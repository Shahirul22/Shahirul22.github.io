---
import { experiences } from '../lib/data';
---
<ol class="relative border-l-2 border-ink-200 dark:border-ink-800 ml-3 space-y-10">
  {experiences.map((exp, i) => (
    <li class="pl-6 reveal" style={`transition-delay:${i * 120}ms`}>
      <span class="absolute -left-[9px] mt-1.5 w-4 h-4 rounded-full bg-accent ring-4 ring-accent/20 animate-floaty"></span>
      <div class="flex flex-wrap items-baseline justify-between gap-2">
        <h3 class="text-lg font-bold text-ink-900 dark:text-ink-50">
          {exp.role} <span class="text-accent">@ {exp.company}</span>
        </h3>
        <span class="font-mono text-xs text-ink-500 dark:text-ink-400">{exp.period}</span>
      </div>
      {exp.location && <p class="text-xs text-ink-500 dark:text-ink-400 mb-3">{exp.location}</p>}
      <ul class="list-disc list-outside pl-5 space-y-1.5 text-sm text-ink-700 dark:text-ink-300 marker:text-accent">
        {exp.bullets.map((b) => <li>{b}</li>)}
      </ul>
      <div class="mt-3 flex flex-wrap gap-1.5">
        {exp.tags.map((t) => <span class="badge">{t}</span>)}
      </div>
    </li>
  ))}
</ol>
